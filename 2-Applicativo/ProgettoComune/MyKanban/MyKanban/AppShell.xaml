<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MyKanban"
       x:Class="MyKanban.AppShell">

    <!-- TOP BAR GLOBALE -->
    <Shell.TitleView>
        <Grid BackgroundColor="#D0D0D0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <Button Grid.Column="0" 
                    Text="☰"
                        BackgroundColor="#3A3A3A"
                        TextColor="White" FontSize="16"
                        FontAttributes="Bold" 
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Clicked="OnMenuClicked" CornerRadius="100" Margin="10,0"/>

            <Border Grid.Column="1" StrokeShape="RoundRectangle 40" Margin="10,0,0,0" HeightRequest="40">
                <SearchBar Placeholder="Search items..."
                           Background="White"
                           TextColor="Black"
             />
            </Border>
            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="8"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End" Margin="20,0,0,0">
                <Label Text="Nome Utente"
                       FontSize="13"
                       VerticalOptions="Center"
                       TextColor="#333"/>

                <Label Text="&#x1F464;" FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
            </HorizontalStackLayout>

        </Grid>
    </Shell.TitleView>

    <!-- Le tue pagine -->
    <ShellContent 
                  ContentTemplate="{DataTemplate views:MainPage}"/>

